# OpenAI API
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4o-mini
OPENAI_VISION_MODEL=gpt-4o-mini
TEMPERATURE=0.7

# GigaChat API (assistant_giga)
GIGACHAT_AUTH_KEY=your-gigachat-auth-key
GIGACHAT_SCOPE=GIGACHAT_API_PERS
GIGACHAT_RQUID=your-uuid-v4

# RAGAS evaluation (optional, defaults to OPENAI_MODEL)
RAGAS_LLM_MODEL=gpt-4o-mini

# Telegram Bot (optional)
TELEGRAM_TOKEN=your-telegram-bot-token
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# Vector DB providers (optional)
PINECONE_API_KEY=
PINECONE_ENVIRONMENT=us-east-1-aws
PINECONE_INDEX_NAME=rag-demo-index
WEAVIATE_URL=
WEAVIATE_API_KEY=
CHROMA_API_KEY=
